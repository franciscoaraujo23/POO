    { "id": "mqilso6pq3bhu", "data": "2026-06-17T21:49:11.665Z", "modo": "gratidao", "campos": { "g1": "ww", "g2": "aa", "g3": "qqq" }, "userId": "9" },
    { "id": "ref8a", "data": "2026-06-06T21:00:00.000Z", "modo": "estoico",  "campos": { "problema": "Dificuldade em equilibrar trabalho e vida pessoal.", "controlo": "Posso definir limites claros e cumprir horários.", "passo": "Esta semana saio do trabalho à hora certa todos os dias." }, "userId": "8" },
    { "id": "ref8b", "data": "2026-06-09T20:30:00.000Z", "modo": "livre",    "campos": { "texto": "Tenho notado que quando medito regularmente o meu nível de energia aumenta. Vale a pena continuar." }, "userId": "8" },
    { "id": "ref8c", "data": "2026-06-11T21:15:00.000Z", "modo": "gratidao", "campos": { "g1": "Ter saúde para fazer exercício.", "g2": "Um projeto interessante no trabalho.", "g3": "Amigos que me apoiam." }, "userId": "8" },
    { "id": "ref8d", "data": "2026-06-14T20:00:00.000Z", "modo": "livre",    "campos": { "texto": "Semana muito produtiva. Sinto que estou a crescer tanto a nível pessoal como profissional." }, "userId": "8" },
