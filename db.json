  "reflexoes": [
    { "id": "mq9jbi55hpoih", "data": "2026-06-11T13:29:55.865Z", "modo": "estoico",  "campos": { "problema": "Boas", "controlo": "Dest", "passo": "Dá" }, "userId": 3 },
    { "id": "ref3a", "data": "2026-06-05T21:00:00.000Z", "modo": "livre",    "campos": { "texto": "Hoje foi difícil. Sinto que estou a deixar a ansiedade controlar-me demasiado. Preciso de trabalhar nisso." }, "userId": "3" },
    { "id": "ref3b", "data": "2026-06-08T22:00:00.000Z", "modo": "estoico",  "campos": { "problema": "Pressão no trabalho e medo do futuro.", "controlo": "Posso controlar o meu esforço e a minha atitude diária.", "passo": "Amanhã faço uma lista de tarefas e foco-me numa de cada vez." }, "userId": "3" },
    { "id": "ref3c", "data": "2026-06-12T21:30:00.000Z", "modo": "gratidao", "campos": { "g1": "Ter conseguido dormir melhor esta semana.", "g2": "Uma conversa boa com um amigo.", "g3": "Sentir que estou a progredir." }, "userId": "3" },
    { "id": "ref3d", "data": "2026-06-15T20:00:00.000Z", "modo": "estoico",  "campos": { "problema": "Preocupação constante com coisas que não controlo.", "controlo": "Só consigo controlar as minhas ações e a forma como reajo.", "passo": "Meditar 10 minutos todas as manhãs esta semana." }, "userId": "3" },
    { "id": "ref6a", "data": "2026-06-11T09:30:00.000Z", "modo": "estoico",  "campos": { "problema": "Sinto que não consigo gerir o tempo.", "controlo": "Posso organizar melhor as minhas tarefas e definir prioridades.", "passo": "Amanhã começo o dia com uma lista de 3 prioridades." }, "userId": 6 },
    { "id": "ref6b", "data": "2026-06-10T22:00:00.000Z", "modo": "livre",    "campos": { "texto": "Hoje foi um dia tranquilo. Consegui fazer uma pausa a meio da tarde e isso fez toda a diferença." }, "userId": 6 },
    { "id": "ref6c", "data": "2026-06-09T21:15:00.000Z", "modo": "gratidao", "campos": { "g1": "Ter tido uma conversa honesta com um amigo.", "g2": "O café da manhã em silêncio.", "g3": "Conseguir terminar o que comecei." }, "userId": 6 },
    { "id": "ref6d", "data": "2026-06-08T20:45:00.000Z", "modo": "livre",    "campos": { "texto": "Preciso de descansar mais. Noto que quando durmo mal tudo parece mais complicado do que realmente é." }, "userId": 6 },
    { "id": "ref6e", "data": "2026-06-07T19:00:00.000Z", "modo": "estoico",  "campos": { "problema": "Discussão com um colega de trabalho.", "controlo": "Posso controlar a forma como reajo e comunicar com calma.", "passo": "Pedir uma conversa tranquila amanhã." }, "userId": 6 },
    { "id": "ref6f", "data": "2026-06-06T21:30:00.000Z", "modo": "gratidao", "campos": { "g1": "A saúde da minha família.", "g2": "Um dia sem grandes problemas.", "g3": "Ter conseguido descansar bem." }, "userId": 6 },
    { "id": "mqi66ye6pf87c", "data": "2026-06-17T14:32:24.222Z", "modo": "livre",    "campos": { "texto": "Boas brother.." }, "userId": "4" },
    { "id": "ref4a", "data": "2026-06-06T22:00:00.000Z", "modo": "estoico",  "campos": { "problema": "Não consigo parar de pensar no passado e no futuro ao mesmo tempo.", "controlo": "Posso treinar a minha mente para focar no momento presente.", "passo": "Fazer uma sessão de meditação antes de dormir esta semana." }, "userId": "4" },
    { "id": "ref4b", "data": "2026-06-09T21:30:00.000Z", "modo": "gratidao", "campos": { "g1": "Ter tido tempo para mim hoje.", "g2": "Uma boa conversa com a família.", "g3": "Sentir que a meditação está a ajudar." }, "userId": "4" },
    { "id": "ref4c", "data": "2026-06-13T20:00:00.000Z", "modo": "livre",    "campos": { "texto": "Cada vez consigo estar mais presente. O overthinking ainda existe mas já consigo observá-lo sem me perder nele." }, "userId": "4" },
    { "id": "ref4d", "data": "2026-06-16T21:00:00.000Z", "modo": "estoico",  "campos": { "problema": "Preocupação com decisões importantes que tenho de tomar.", "controlo": "Posso recolher informação e decidir com calma.", "passo": "Escrever os prós e contras amanhã com a cabeça fria." }, "userId": "4" },
    { "id": "mqilq198nyijl", "data": "2026-06-17T21:47:08.636Z", "modo": "gratidao", "campos": { "g1": "1",  "g2": "2",  "g3": "3"   }, "userId": "9" },
